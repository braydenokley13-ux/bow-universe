generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  ADMIN
}

enum GradeBand {
  GRADE_5_6
  GRADE_7_8
}

enum MarketSizeTier {
  SMALL
  MID
  LARGE
  MEGA
}

enum LaneTag {
  TOOL_BUILDERS
  POLICY_REFORM_ARCHITECTS
  STRATEGIC_OPERATORS
  ECONOMIC_INVESTIGATORS
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  REVISION_REQUESTED
  APPROVED_FOR_INTERNAL_PUBLICATION
  PUBLISHED_INTERNAL
  MARKED_EXTERNAL_READY
  APPROVED_FOR_EXTERNAL_PUBLICATION
}

enum ProposalStatus {
  DRAFT
  SUBMITTED
  REVISION_REQUESTED
  APPROVED_FOR_INTERNAL_PUBLICATION
  READY_FOR_VOTING
  VOTING
  DECISION
  PUBLISHED_INTERNAL
  MARKED_EXTERNAL_READY
  APPROVED_FOR_EXTERNAL_PUBLICATION
}

enum VoteValue {
  YES
  NO
}

enum DecisionType {
  APPROVE
  DENY
  AMEND
}

enum IssueStatus {
  OPEN
  IN_REVIEW
  RESOLVED
}

enum ProjectType {
  TOOL
  INVESTIGATION
  STRATEGY
  PROPOSAL_SUPPORT
}

enum PublicationType {
  TOOL_BRIEF
  POLICY_MEMO
  TEAM_STRATEGY_DOSSIER
  RESEARCH_BRIEF
}

enum FeedbackType {
  CLARITY
  EVIDENCE
  REASONING
  STRUCTURE
  REVISION_REQUEST
}

enum PublicationSourceType {
  PROJECT
  PROPOSAL
}

enum ExternalPublicationTarget {
  WEB
  PDF
}

enum ChallengeEntryType {
  PROJECT
  PROPOSAL
  EITHER
}

enum ChallengeScoreEventKind {
  JOIN
  SUBMIT
  APPROVED_INTERNAL
  PUBLISHED_INTERNAL
  SPOTLIGHT
}

enum StudentOutcomeKind {
  ARTIFACT_COMPLETED
  EVIDENCE_DEFENDED
  VERIFIED_IMPACT
}

enum StudentOutcomeStatus {
  DRAFT
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
}

model User {
  id                    String                 @id @default(cuid())
  name                  String
  email                 String                 @unique
  passwordHash          String
  role                  UserRole               @default(STUDENT)
  gradeBand             GradeBand?
  linkedTeamId          String?
  commissionerId        String?
  signedUpViaClassCodeId String?
  createdAt             DateTime               @default(now())
  onboardingCompletedAt DateTime?
  onboardingExperienceVersion Int              @default(0)
  onboardingProgressJson Json?
  linkedTeam            Team?                  @relation("LinkedStudentTeam", fields: [linkedTeamId], references: [id], onDelete: SetNull)
  commissioner          User?                  @relation("CommissionerLinkedStudents", fields: [commissionerId], references: [id], onDelete: SetNull)
  signedUpViaClassCode  ClassCode?             @relation("ClassCodeSignups", fields: [signedUpViaClassCodeId], references: [id], onDelete: SetNull)
  linkedStudents        User[]                 @relation("CommissionerLinkedStudents")
  createdRuleSets       RuleSet[]              @relation("RuleSetCreatedBy")
  createdProposals      Proposal[]             @relation("ProposalCreatedBy")
  createdIssues         Issue[]                @relation("IssueCreatedBy")
  createdProjects       Project[]              @relation("ProjectCreatedBy")
  createdComments       ProjectComment[]
  votes                 Vote[]
  decisions             CommissionerDecision[] @relation("DecisionByUser")
  projectCollaborations ProjectCollaborator[]
  activityEvents        ActivityEvent[]        @relation("ActivityByUser")
  projectFeedback       ProjectFeedback[]      @relation("ProjectFeedbackByUser")
  proposalFeedback      ProposalFeedback[]     @relation("ProposalFeedbackByUser")
  projectRevisions      ProjectRevision[]      @relation("ProjectRevisionByUser")
  proposalRevisions     ProposalRevision[]     @relation("ProposalRevisionByUser")
  publishedPublications Publication[]          @relation("PublicationPublishedBy")
  createdStudentInvites StudentInvite[]        @relation("StudentInviteCreatedBy")
  studentInvites        StudentInvite[]        @relation("StudentInviteUser")
  createdClassCodes     ClassCode[]            @relation("ClassCodeCreatedBy")
  authoredNewsPosts     NewsPost[]             @relation("NewsPostAuthoredBy")
  createdChallenges     Challenge[]            @relation("ChallengeCreatedBy")
  challengeEntries      ChallengeEntry[]       @relation("ChallengeEntryByUser")
  challengeScoreEvents  ChallengeScoreEvent[]  @relation("ChallengeScoreEventByUser")
  createdCohorts        Cohort[]               @relation("CohortCreatedBy")
  cohortMemberships     CohortMember[]         @relation("CohortMemberships")
  studentOutcomes       StudentOutcome[]       @relation("StudentOutcomeOwner")
  verifiedOutcomes      StudentOutcome[]       @relation("StudentOutcomeVerifiedBy")

  @@index([linkedTeamId])
  @@index([commissionerId])
  @@index([signedUpViaClassCodeId])
  @@index([gradeBand])
}

model Team {
  id                   String       @id @default(cuid())
  name                 String
  slug                 String       @unique
  marketSizeTier       MarketSizeTier
  ownerProfile         String
  ownerDisciplineScore Float
  createdAt            DateTime     @default(now())
  contracts            Contract[]
  teamSeasons          TeamSeason[]
  projects             Project[]
  issues               Issue[]
  publications         Publication[]
  linkedStudents       User[]       @relation("LinkedStudentTeam")
  classCodes           ClassCode[]
  challenges           Challenge[]
}

model StudentInvite {
  id              String   @id @default(cuid())
  token           String   @unique
  userId          String
  createdByUserId String
  createdAt       DateTime @default(now())
  expiresAt       DateTime
  usedAt          DateTime?
  user            User     @relation("StudentInviteUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy       User     @relation("StudentInviteCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdByUserId, createdAt])
  @@index([usedAt])
}

model ClassCode {
  id              String   @id @default(cuid())
  code            String   @unique
  label           String
  description     String?
  commissionerId  String
  linkedTeamId    String?
  defaultGradeBand GradeBand?
  cohortId        String?
  active          Boolean  @default(true)
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  commissioner    User     @relation("ClassCodeCreatedBy", fields: [commissionerId], references: [id], onDelete: Cascade)
  linkedTeam      Team?    @relation(fields: [linkedTeamId], references: [id], onDelete: SetNull)
  cohort          Cohort?  @relation(fields: [cohortId], references: [id], onDelete: SetNull)
  signups         User[]   @relation("ClassCodeSignups")

  @@index([commissionerId, createdAt])
  @@index([linkedTeamId])
  @@index([cohortId])
  @@index([active, expiresAt])
}

model Season {
  id              String      @id @default(cuid())
  year            Int         @unique
  activeRuleSetId String
  capNumber       Float
  createdAt       DateTime    @default(now())
  activeRuleSet   RuleSet     @relation("SeasonActiveRuleSet", fields: [activeRuleSetId], references: [id], onDelete: Restrict)
  teamSeasons     TeamSeason[]
  publications    Publication[]

  @@index([activeRuleSetId])
  @@index([createdAt])
}

model Contract {
  id               String   @id @default(cuid())
  teamId           String
  playerName       String
  startYear        Int
  years            Int
  annualSalaryJson Json
  notes            String?
  team             Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

model TeamSeason {
  id               String   @id @default(cuid())
  teamId           String
  seasonId         String
  payroll          Float
  taxPaid          Float
  revenue          Float
  valuation        Float
  performanceProxy Float
  createdAt        DateTime @default(now())
  season           Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team             Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, seasonId])
  @@index([seasonId])
}

model RuleSet {
  id                  String     @id @default(cuid())
  version             Int        @unique
  isActive            Boolean    @default(false)
  rulesJson           Json
  changeSummaryJson   Json?
  effectiveSeasonYear Int?
  sourceProposalId    String?
  createdAt           DateTime   @default(now())
  createdByUserId     String
  createdBy           User       @relation("RuleSetCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  seasons             Season[]   @relation("SeasonActiveRuleSet")
  targetProposals     Proposal[] @relation("ProposalTargetRuleSet")
  sourceProposal      Proposal?  @relation("RuleSetSourceProposal", fields: [sourceProposalId], references: [id], onDelete: SetNull)

  @@index([createdByUserId])
  @@index([effectiveSeasonYear])
  @@index([isActive])
  @@index([createdAt])
}

model Proposal {
  id                               String                 @id @default(cuid())
  title                            String
  issueId                          String
  createdByUserId                  String
  status                           ProposalStatus         @default(DRAFT)
  publicationType                  PublicationType        @default(POLICY_MEMO)
  ruleSetIdTarget                  String
  diffJson                         Json
  narrativeJson                    Json
  contentJson                      Json?
  reviewChecklistJson              Json?
  sandboxResultJson                Json?
  abstract                         String?
  methodsSummary                   String?
  keyTakeawaysJson                 Json?
  referencesJson                   Json?
  keywordsJson                     Json?
  publicationSummary               String?
  publicationSlug                  String?                @unique
  publicationVersion               Int                    @default(1)
  voteStart                        DateTime?
  voteEnd                          DateTime?
  submittedAt                      DateTime?
  revisionRequestedAt              DateTime?
  approvedForInternalPublicationAt DateTime?
  readyForVotingAt                 DateTime?
  publishedInternalAt              DateTime?
  markedExternalReadyAt            DateTime?
  approvedForExternalPublicationAt DateTime?
  createdAt                        DateTime               @default(now())
  updatedAt                        DateTime               @updatedAt
  issue                            Issue                  @relation(fields: [issueId], references: [id], onDelete: Restrict)
  createdBy                        User                   @relation("ProposalCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  targetRuleSet                    RuleSet                @relation("ProposalTargetRuleSet", fields: [ruleSetIdTarget], references: [id], onDelete: Restrict)
  votes                            Vote[]
  decision                         CommissionerDecision?
  supportingProjects Project[]
  sourceRuleSets                   RuleSet[]              @relation("RuleSetSourceProposal")
  feedbackEntries                  ProposalFeedback[]
  revisions                        ProposalRevision[]

  @@index([issueId])
  @@index([createdByUserId])
  @@index([ruleSetIdTarget])
  @@index([status])
  @@index([publicationSlug])
  @@index([createdAt])
  @@index([voteStart, voteEnd])
}

model Vote {
  id         String    @id @default(cuid())
  proposalId String
  userId     String
  value      VoteValue
  createdAt  DateTime  @default(now())
  proposal   Proposal  @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([proposalId, userId])
  @@index([userId])
}

model CommissionerDecision {
  id              String       @id @default(cuid())
  proposalId      String       @unique
  decidedByUserId String
  decision        DecisionType
  notes           String?
  amendedDiffJson Json?
  decidedAt       DateTime     @default(now())
  proposal        Proposal     @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  decidedBy       User         @relation("DecisionByUser", fields: [decidedByUserId], references: [id], onDelete: Restrict)

  @@index([decidedByUserId])
}

model Issue {
  id              String       @id @default(cuid())
  title           String
  slug            String       @unique
  description     String
  severity        Int
  status          IssueStatus  @default(OPEN)
  metricsJson     Json?
  evidenceMd      String?
  teamId          String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  createdByUserId String
  createdBy       User         @relation("IssueCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  team            Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  proposals       Proposal[]
  primaryProjects Project[]    @relation("PrimaryProjectIssue")
  projectLinks    ProjectIssue[]
  publications    Publication[]
  challenges      Challenge[]

  @@index([status])
  @@index([severity])
  @@index([teamId])
  @@index([createdByUserId])
  @@index([createdAt])
}

model Project {
  id                               String           @id @default(cuid())
  title                            String
  summary                          String
  projectType                      ProjectType
  submissionStatus                 SubmissionStatus @default(DRAFT)
  publicationType                  PublicationType
  lanePrimary                      LaneTag?
  laneTagsJson                     Json
  issueId                          String?
  teamId                           String?
  supportingProposalId             String?
  artifactLinksJson                Json
  findingsMd                       String
  contentJson                      Json?
  reviewChecklistJson              Json?
  abstract                         String?
  essentialQuestion                String?
  methodsSummary                   String?
  keyTakeawaysJson                 Json?
  referencesJson                   Json?
  keywordsJson                     Json?
  publicationSummary               String?
  publicationSlug                  String?          @unique
  publicationVersion               Int              @default(1)
  createdByUserId                  String
  submittedAt                      DateTime?
  revisionRequestedAt              DateTime?
  approvedForInternalPublicationAt DateTime?
  publishedInternalAt              DateTime?
  markedExternalReadyAt            DateTime?
  approvedForExternalPublicationAt DateTime?
  createdAt                        DateTime         @default(now())
  updatedAt                        DateTime         @updatedAt
  primaryIssue                     Issue?           @relation("PrimaryProjectIssue", fields: [issueId], references: [id], onDelete: SetNull)
  team                             Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  supportingProposal               Proposal?        @relation(fields: [supportingProposalId], references: [id], onDelete: SetNull)
  createdBy                        User             @relation("ProjectCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  issueLinks                       ProjectIssue[]
  collaborators                    ProjectCollaborator[]
  comments                         ProjectComment[]
  feedbackEntries                  ProjectFeedback[]
  revisions                        ProjectRevision[]

  @@index([issueId])
  @@index([teamId])
  @@index([createdByUserId])
  @@index([projectType])
  @@index([submissionStatus])
  @@index([publicationSlug])
  @@index([supportingProposalId])
  @@index([createdAt])
}

model ProjectIssue {
  projectId String
  issueId   String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issue     Issue   @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@id([projectId, issueId])
  @@index([issueId])
}

model ProjectCollaborator {
  projectId String
  userId    String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@index([userId])
}

model ProjectComment {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  body      String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
}

model ProjectFeedback {
  id              String       @id @default(cuid())
  projectId       String
  sectionKey      String
  feedbackType    FeedbackType
  body            String
  createdByUserId String
  createdAt       DateTime     @default(now())
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy       User         @relation("ProjectFeedbackByUser", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdByUserId])
  @@index([createdAt])
}

model ProposalFeedback {
  id              String       @id @default(cuid())
  proposalId      String
  sectionKey      String
  feedbackType    FeedbackType
  body            String
  createdByUserId String
  createdAt       DateTime     @default(now())
  proposal        Proposal     @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdBy       User         @relation("ProposalFeedbackByUser", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@index([createdByUserId])
  @@index([createdAt])
}

model ProjectRevision {
  id              String   @id @default(cuid())
  projectId       String
  snapshotJson    Json
  createdByUserId String
  createdAt       DateTime @default(now())
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy       User     @relation("ProjectRevisionByUser", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdByUserId])
  @@index([createdAt])
}

model ProposalRevision {
  id              String   @id @default(cuid())
  proposalId      String
  snapshotJson    Json
  createdByUserId String
  createdAt       DateTime @default(now())
  proposal        Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdBy       User     @relation("ProposalRevisionByUser", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@index([createdByUserId])
  @@index([createdAt])
}

model Publication {
  id                 String                    @id @default(cuid())
  slug               String                    @unique
  title              String
  publicationType    PublicationType
  sourceType         PublicationSourceType
  sourceId           String
  lanePrimary        LaneTag?
  abstract           String
  summary            String
  keywordsJson       Json?
  citationText       String
  authorLine         String
  publishedAt        DateTime
  publishedByUserId  String
  seasonId           String?
  issueId            String?
  teamId             String?
  externalReady      Boolean                   @default(false)
  externalApproved   Boolean                   @default(false)
  externalTargetsJson Json?
  canonicalVersion   Int                       @default(1)
  layoutVersion      Int                       @default(1)
  metadataJson       Json?
  publishedBy        User                      @relation("PublicationPublishedBy", fields: [publishedByUserId], references: [id], onDelete: Restrict)
  season             Season?                   @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  issue              Issue?                    @relation(fields: [issueId], references: [id], onDelete: SetNull)
  team               Team?                     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  exports            PublicationExport[]

  @@unique([sourceType, sourceId])
  @@index([publishedByUserId])
  @@index([seasonId])
  @@index([issueId])
  @@index([teamId])
  @@index([publicationType])
  @@index([lanePrimary])
  @@index([publishedAt])
}

model StudentOutcome {
  id               String               @id @default(cuid())
  userId           String
  sourceType       PublicationSourceType
  sourceId         String
  kind             StudentOutcomeKind
  status           StudentOutcomeStatus @default(DRAFT)
  studentSummary   String?
  proofJson        Json?
  submittedAt      DateTime?
  verifiedAt       DateTime?
  verifiedByUserId String?
  reviewNote       String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  user             User                 @relation("StudentOutcomeOwner", fields: [userId], references: [id], onDelete: Cascade)
  verifiedBy       User?                @relation("StudentOutcomeVerifiedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull)

  @@unique([sourceType, sourceId, kind])
  @@index([userId, kind, status])
  @@index([sourceType, sourceId])
  @@index([status, createdAt])
  @@index([verifiedByUserId])
}

model PublicationExport {
  id           String                    @id @default(cuid())
  publicationId String
  target       ExternalPublicationTarget
  status       String
  generatedAt  DateTime?
  artifactUrl  String?
  notes        String?
  publication  Publication               @relation(fields: [publicationId], references: [id], onDelete: Cascade)

  @@unique([publicationId, target])
  @@index([status])
}

model ActivityEvent {
  id              String   @id @default(cuid())
  type            String
  title           String
  summary         String
  entityType      String?
  entityId        String?
  metadataJson    Json?
  createdAt       DateTime @default(now())
  createdByUserId String?
  createdBy       User?    @relation("ActivityByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([createdByUserId])
}

model NewsPost {
  id               String   @id @default(cuid())
  slug             String   @unique
  headline         String
  dek              String
  bodyMd           String
  linkedEntityType String?
  linkedEntityId   String?
  pinned           Boolean  @default(false)
  publishedAt      DateTime @default(now())
  createdAt        DateTime @default(now())
  authorUserId     String
  author           User     @relation("NewsPostAuthoredBy", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([publishedAt])
  @@index([pinned, publishedAt])
  @@index([linkedEntityType, linkedEntityId])
  @@index([authorUserId, createdAt])
}

model Challenge {
  id               String             @id @default(cuid())
  slug             String             @unique
  title            String
  summary          String
  prompt           String
  scoringNotesMd   String?
  laneTag          LaneTag?
  issueId          String?
  teamId           String?
  allowedEntryType ChallengeEntryType @default(EITHER)
  startsAt         DateTime
  endsAt           DateTime
  active           Boolean            @default(true)
  createdAt        DateTime           @default(now())
  createdByUserId  String
  createdBy        User               @relation("ChallengeCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  issue            Issue?             @relation(fields: [issueId], references: [id], onDelete: SetNull)
  team             Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  entries          ChallengeEntry[]

  @@index([createdByUserId, createdAt])
  @@index([issueId])
  @@index([teamId])
  @@index([laneTag])
  @@index([active, startsAt, endsAt])
}

model ChallengeEntry {
  id           String                @id @default(cuid())
  challengeId  String
  userId       String
  sourceType   PublicationSourceType
  sourceId     String
  joinedAt     DateTime              @default(now())
  spotlightedAt DateTime?
  challenge    Challenge             @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user         User                  @relation("ChallengeEntryByUser", fields: [userId], references: [id], onDelete: Cascade)
  scoreEvents  ChallengeScoreEvent[]

  @@unique([challengeId, userId])
  @@unique([challengeId, sourceType, sourceId])
  @@index([userId, joinedAt])
  @@index([sourceType, sourceId])
}

model ChallengeScoreEvent {
  id              String                  @id @default(cuid())
  challengeEntryId String
  kind            ChallengeScoreEventKind
  points          Int
  note            String?
  createdAt       DateTime                @default(now())
  createdByUserId String?
  challengeEntry  ChallengeEntry          @relation(fields: [challengeEntryId], references: [id], onDelete: Cascade)
  createdBy       User?                   @relation("ChallengeScoreEventByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([challengeEntryId, kind])
  @@index([createdByUserId, createdAt])
  @@index([kind, createdAt])
}

model GlossaryTerm {
  id         String   @id @default(cuid())
  slug       String   @unique
  term       String
  definition String
  bowExample String?
  category   String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([category])
  @@index([slug])
  @@index([sortOrder])
}

model Cohort {
  id              String            @id @default(cuid())
  name            String
  description     String?
  createdByUserId String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  createdBy       User              @relation("CohortCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  classCodes      ClassCode[]
  members         CohortMember[]
  milestones      CohortMilestone[]

  @@index([createdByUserId])
}

model CohortMember {
  cohortId String
  userId   String
  joinedAt DateTime @default(now())
  cohort   Cohort   @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user     User     @relation("CohortMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@id([cohortId, userId])
  @@index([userId])
}

model CohortMilestone {
  id          String   @id @default(cuid())
  cohortId    String
  label       String
  targetDate  DateTime
  description String?
  cohort      Cohort   @relation(fields: [cohortId], references: [id], onDelete: Cascade)

  @@index([cohortId])
  @@index([targetDate])
}
